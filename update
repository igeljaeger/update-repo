#!/bin/bash

LOG_FILE="/tmp/updates.log"
green='\033[0;32m'
yellow='\033[0;33m'
red='\033[0;31m'
nc='\033[0m'

export PATH="$HOME/.local/bin:$HOME/.deno/bin:$PATH"

exec > >(tee -a "$LOG_FILE") 2>&1

is_debian_or_devuan() {
    grep -qiE "debian|devuan" /etc/*release 2>/dev/null
}

install_brave_origin_nightly() {
    if ! dpkg -s brave-origin-nightly >/dev/null 2>&1; then
        echo -e "${green}Installing Brave Origin Nightly...${nc}"
        sudo apt install -y curl
        sudo curl -fsSLo /usr/share/keyrings/brave-browser-nightly-archive-keyring.gpg \
            https://brave-browser-apt-nightly.s3.brave.com/brave-browser-nightly-archive-keyring.gpg
        sudo curl -fsSLo /etc/apt/sources.list.d/brave-browser-nightly.sources \
            https://brave-browser-apt-nightly.s3.brave.com/brave-browser.sources
        sudo apt update
        sudo apt install -y brave-origin-nightly
    fi
}

install_yt_dlp() {
    if ! command -v yt-dlp >/dev/null 2>&1 && [ ! -x "$HOME/.local/bin/yt-dlp" ]; then
        echo -e "${green}Installing yt-dlp...${nc}"
        mkdir -p "$HOME/.local/bin"
        curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o "$HOME/.local/bin/yt-dlp"
        chmod a+rx "$HOME/.local/bin/yt-dlp"
    fi
}

install_deno() {
    if ! command -v deno >/dev/null 2>&1 && [ ! -x "$HOME/.deno/bin/deno" ]; then
        echo -e "${green}Installing Deno...${nc}"
        curl -fsSL https://deno.land/install.sh | sh
    fi
}

install_required_apt_packages() {
    local packages=(
        partitionmanager
        unrar
        vim
        steam-devices
        adb
        ffmpeg
        syncplay
        fastfetch
        mpv
        flatpak
        plasma-discover-backend-flatpak
    )
    local missing=()
    local pkg

    for pkg in "${packages[@]}"; do
        if ! dpkg -s "$pkg" >/dev/null 2>&1; then
            missing+=("$pkg")
        fi
    done

    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${green}Installing required APT packages...${nc}"
        sudo apt install -y "${missing[@]}"
    fi
}

install_ani_cli() {
    if ! command -v ani-cli >/dev/null 2>&1 && [ ! -x "$HOME/.local/bin/ani-cli" ]; then
        echo -e "${green}Installing ani-cli...${nc}"
        mkdir -p "$HOME/.local/bin"
        curl -L https://github.com/pystardust/ani-cli/releases/latest/download/ani-cli -o "$HOME/.local/bin/ani-cli" \
            || curl -L https://raw.githubusercontent.com/pystardust/ani-cli/master/ani-cli -o "$HOME/.local/bin/ani-cli"
        chmod a+rx "$HOME/.local/bin/ani-cli"
    fi
}

if ! is_debian_or_devuan; then
    echo -e "${red}Unsupported distribution. Exiting.${nc}"
    exit 1
fi

echo -e "${green}Detected Debian/Devuan system.${nc}"

echo -e "${green}Updating APT packages...${nc}"
sudo apt update
sudo apt upgrade -y
sudo apt autoremove -y

install_brave_origin_nightly
install_required_apt_packages
install_yt_dlp
install_deno
install_ani_cli

if command -v snap >/dev/null 2>&1 || dpkg -s snapd >/dev/null 2>&1; then
    echo -e "${green}snapd is installed; refreshing snaps...${nc}"
    if command -v snap >/dev/null 2>&1; then
        sudo snap refresh
    else
        echo -e "${yellow}snap command not available even though snapd is installed.${nc}"
    fi
fi

if command -v flatpak >/dev/null 2>&1; then
    echo -e "${green}Updating Flatpaks...${nc}"

    if ! flatpak remotes --user --columns=name | grep -qxF flathub; then
        echo -e "${yellow}User Flathub not configured.${nc}"
        read -p "Add user Flathub repository now? [y/N] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            flatpak remote-add --user --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
        fi
    fi

    flatpak update --user -y >/dev/null 2>&1
    flatpak uninstall --user --unused -y >/dev/null 2>&1

else
    echo -e "${yellow}Flatpak is not installed.${nc}"
    read -p "Install Flatpak now? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        sudo apt install -y flatpak
        echo -e "${green}Flatpak installed. Rerun to add user Flathub and update.${nc}"
    fi
fi

echo -e "${green}All updates complete.${nc}"

read -p "Shutdown now? [y/N] " -n 1 -r
echo
if [[ $REPLY =~ ^[Yy]$ ]]; then
    echo -e "${yellow}Shutting down: syncing, closing crypt devices, and powering off...${nc}"
    sudo shutdown now
fi

echo -e "${green}Update script finished.${nc}"
